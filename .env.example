# ─── FIREBASE CONFIG ─────────────────────────────────────────────────────────
# Get these from your Firebase Console → Project Settings → Web App
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ─── LINKEDIN OAUTH ───────────────────────────────────────────────────────────
# Get from: https://www.linkedin.com/developers/apps → Create App
# Set Redirect URL to: http://localhost:3000/auth/linkedin/callback
VITE_LINKEDIN_CLIENT_ID=your_linkedin_client_id
VITE_LINKEDIN_REDIRECT_URI=http://localhost:3000/auth/linkedin/callback

# ─── OPTIONAL: AI RESUME GENERATION ──────────────────────────────────────────
# If using OpenAI for AI resume generation
VITE_OPENAI_API_KEY=your_openai_key_here
